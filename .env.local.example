NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Use either the legacy anon JWT or the new publishable key (Project Settings → API).
# Leave ANON_KEY unset or omit it if you only use publishable — an empty ANON_KEY is ignored.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-jwt
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# After editing env files, stop and run `npm run dev` again so the browser bundle picks up changes.
